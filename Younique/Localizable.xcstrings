      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manual selection"
          }
        }
      }
    },
    "Handmatige selectie met positieverdeling: alleen jouw gekozen lettergrepen worden gebruikt, verdeeld per positie." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manual selection with position distribution: only your chosen syllables are used, distributed per position."
          }
        }
      }
    },
    "Handmatige selectie zonder positieverdeling: elke positie gebruikt dezelfde gekozen lettergrepen." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manual selection without position distribution: every position uses the same chosen syllables."
