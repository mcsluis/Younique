            "value" : "Next"
          }
        }
      }
    },
    "Volledig handmatig: per positie bepaal je zelf welke lettergrepen beschikbaar zijn." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
